                };

                @vertex
                fn vs_main(input: VertexInput) -> VertexOutput {
                    var output: VertexOutput;

                    var localPosition = vec4f(0.0);

                    var inputPosition = vec4f(input.vertexPosition, 1.0);

                    for (var i: i32 = 0; i < fyrox_instanceData.blendShapesCount; i++) {
